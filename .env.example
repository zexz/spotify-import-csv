# Spotify API credentials.
# Fill these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Input/output files.
CSV_FILE=tracks.csv
CACHE_FILE=spotify_search_cache.json
STATE_FILE=spotify_import_state.json
NOT_FOUND_FILE=not_found.csv

# Playlist settings.
PLAYLIST_NAME=Imported

# Leave empty to create a new playlist.
# Set to an existing playlist id to add tracks there.
SPOTIFY_PLAYLIST_ID=

# Import controls.
# First track is line 2 because line 1 is the CSV header.
START_LINE=2
SPOTIFY_ADD_BATCH_SIZE=100
SPOTIFY_SEARCH_DELAY_SECONDS=2.5
SPOTIFY_ADD_DELAY_SECONDS=1.0

# If Spotify asks to wait longer than this after a 429,
# the script stops instead of sleeping for hours.
MAX_429_SLEEP_SECONDS=300
MAX_RETRIES=6
SPOTIPY_INTERNAL_RETRIES=0
